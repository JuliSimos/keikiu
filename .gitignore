# Archivos del sistema operativo (Basura que crea Windows y Mac automáticamente)
Thumbs.db
.DS_Store
Desktop.ini

# Carpetas de configuración de editores de código (como VS Code)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Archivos de registro / Logs (Historiales de errores del sistema)
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Carpetas de dependencias (Por si a futuro usas librerías de Node.js)
node_modules/
dist/
build/

# Archivos con contraseñas o claves secretas (¡Súper importante!)
.env
.env.local